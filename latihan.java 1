import java.util.Scanner;

public class latihan {
    public static void main(String[] args) {
        Scanner input = new Scanner(System.in);

    
        System.out.print("Masukkan Nama     : ");
        String nama = input.nextLine();

        System.out.print("Masukkan Umur     : ");
        int umur = input.nextInt();
        input.nextLine();

        System.out.print("Masukkan Prodi    : ");
        String prodi = input.nextLine();

        System.out.print("Masukkan Angkatan : ");
        int angkatan = input.nextInt();
        input.nextLine(); 

    
        String kategoriUmur = "";
        String statusMhs = "";


        if (umur > 18) {
            kategoriUmur = "Dewasa";
        } else if (umur < 18) {
            kategoriUmur = "Muda";
        } else {
            kategoriUmur = "Pas 18 Tahun";
        }

    
        if (umur > 22 && angkatan > 2025) {
            statusMhs = "Mahasiswa in danger";
        } else if (umur < 22 && angkatan < 2025) {
            statusMhs = "Mahasiswa aman";
        } else {
            statusMhs = "Belum Terkonfirmasi";
        }

    
        System.out.println("\n== BIODATA ==");
        System.out.println("Nama          : " + nama);
        System.out.println("Umur          : " + umur);
        System.out.println("Prodi         : " + prodi);
        System.out.println("Angkatan      : " + angkatan);
        System.out.println("Kategori Umur : " + kategoriUmur);
        System.out.println("Status        : " + statusMhs);

        input.close();
    }
}